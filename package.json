{
  "name": "@mjpvs/agentic-component-library-test",
  "version": "1.3.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
